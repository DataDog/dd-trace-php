# Per-developer personal Claude config — never committed.
#
# Everything else committed under .claude/ is the *shared* team config. Keep
# your own memory, notes, commands, scripts, and skills out of git using the
# locations below. See personal/README.md.

/personal/*
!/personal/README.md

/scripts/local/

# Local settings and runtime artifacts.
/settings.local.json
/worktrees/
/.omc/
