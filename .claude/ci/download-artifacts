#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "aiohttp",
# ]
# ///

"""Download CI artifacts from GitLab jobs.

Two modes:
  1. Generic: download artifacts from any job by name or ID.
  2. Preset: download well-known artifacts by key (same set as
     appsec/helper-rust/scripts/check-ci-jobs.py).

Examples:
  # Download a preset artifact for HEAD
  download-artifacts --preset ssi-amd64

  # Download a preset artifact for a specific commit
  download-artifacts --preset extension-amd64-gnu --commit abc123

  # Download artifacts from a job matched by name substring
  download-artifacts --job-name "compile extension: debug [8.3]" --pipeline 12345

  # Download artifacts directly by job ID
  download-artifacts --job-id 98765
"""

import argparse
import asyncio
import os
import subprocess
import sys
import tempfile
import time
import zipfile
from pathlib import Path

import aiohttp

GITLAB_HOST = "https://gitlab.ddbuild.io"
PROJECT_ID = 355
API_BASE = f"{GITLAB_HOST}/api/v4"

# Maps preset key -> exact job name in the package pipeline.
# Same as ARTIFACT_JOBS in appsec/helper-rust/scripts/check-ci-jobs.py.
PRESET_JOBS: dict[str, str] = {
    # Final packages
    "datadog-setup":          "datadog-setup.php",
    "ssi-amd64":              "package loader: [amd64]",
    "ssi-aarch64":            "package loader: [arm64]",
    "extension-amd64-gnu":    "package extension: [amd64, x86_64-unknown-linux-gnu]",
    "extension-aarch64-gnu":  "package extension: [arm64, aarch64-unknown-linux-gnu]",
    "extension-amd64-musl":   "package extension: [amd64, x86_64-alpine-linux-musl]",
    "extension-aarch64-musl": "package extension: [arm64, aarch64-alpine-linux-musl]",
    "extension-windows":      "package extension windows",
    "extension-asan":         "package extension asan",
    # Intermediate compile artifacts (for generate-final-artifact.sh)
    "link-tracing-amd64-gnu":    "link tracing extension: [amd64, x86_64-unknown-linux-gnu]",
    "link-tracing-aarch64-gnu":  "link tracing extension: [arm64, aarch64-unknown-linux-gnu]",
    "link-tracing-amd64-musl":   "link tracing extension: [amd64, x86_64-alpine-linux-musl]",
    "link-tracing-aarch64-musl": "link tracing extension: [arm64, aarch64-alpine-linux-musl]",
    "appsec-helper-cpp-amd64":   "compile appsec helper: [amd64]",
    "appsec-helper-cpp-aarch64": "compile appsec helper: [arm64]",
    "appsec-helper-rust-amd64":  "compile appsec helper rust: [amd64]",
    "appsec-helper-rust-aarch64":"compile appsec helper rust: [arm64]",
}

PIPELINE_DISCOVERY_TIMEOUT = 300  # seconds


# ---------------------------------------------------------------------------
# GitLab API helpers (mirrors the style of check-ci)
# ---------------------------------------------------------------------------

async def api_get(session: aiohttp.ClientSession, path: str, params: dict | None = None) -> tuple[int, any]:
    url = f"{API_BASE}{path}"
    try:
        async with session.get(url, params=params) as resp:
            if resp.status in (401, 403):
                text = await resp.text()
                print(f"Error: authentication failed ({resp.status}): {text}", file=sys.stderr)
                sys.exit(1)
            if resp.content_type and "json" in resp.content_type:
                return resp.status, await resp.json()
            return resp.status, await resp.text()
    except aiohttp.ClientError as e:
        return 0, str(e)


async def api_get_json(session: aiohttp.ClientSession, path: str, params: dict | None = None) -> any:
    status, data = await api_get(session, path, params)
    if status == 0:
        print(f"Warning: network error fetching {path}: {data}", file=sys.stderr)
        return None
    if status >= 400:
        print(f"Warning: HTTP {status} fetching {path}", file=sys.stderr)
        return None
    return data


async def paginated_get(session: aiohttp.ClientSession, path: str, params: dict | None = None) -> list:
    all_items = []
    p = dict(params or {})
    p["per_page"] = 100
    page = 1
    while True:
        p["page"] = page
        data = await api_get_json(session, path, p)
        if data is None or not isinstance(data, list) or len(data) == 0:
            break
        all_items.extend(data)
        if len(data) < 100:
            break
        page += 1
    return all_items


# ---------------------------------------------------------------------------
# Pipeline / job discovery
# ---------------------------------------------------------------------------

def resolve_sha(ref: str) -> str:
    result = subprocess.run(["git", "rev-parse", ref], capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Error: git rev-parse {ref} failed: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


async def get_child_pipelines(session: aiohttp.ClientSession, pipeline_id: int, depth: int = 0) -> list[int]:
    if depth >= 3:
        return []
    bridges = await paginated_get(session, f"/projects/{PROJECT_ID}/pipelines/{pipeline_id}/bridges")
    child_ids = []
    for bridge in bridges:
        downstream = bridge.get("downstream_pipeline")
        if not downstream or not downstream.get("id"):
            continue
        if downstream.get("project_id") != PROJECT_ID:
            continue
        cid = downstream["id"]
        child_ids.append(cid)
        grandchildren = await get_child_pipelines(session, cid, depth + 1)
        child_ids.extend(grandchildren)
    return child_ids


async def get_all_pipeline_ids(session: aiohttp.ClientSession, root_id: int) -> list[int]:
    children = await get_child_pipelines(session, root_id)
    return [root_id] + children


async def discover_root_pipeline(session: aiohttp.ClientSession, sha: str) -> int:
    deadline = time.monotonic() + PIPELINE_DISCOVERY_TIMEOUT
    interval = 15
    while True:
        status, data = await api_get(session, f"/projects/{PROJECT_ID}/pipelines", {"sha": sha, "per_page": 20})
        if status >= 400 or status == 0:
            print(f"Error: failed to query pipelines for {sha} (HTTP {status})", file=sys.stderr)
            sys.exit(1)
        if isinstance(data, list) and len(data) > 0:
            best = max(data, key=lambda p: p.get("updated_at", ""))
            print(f"Found pipeline {best['id']} (status: {best.get('status', 'unknown')})")
            return best["id"]
        if time.monotonic() >= deadline:
            print(f"Error: no pipeline found for SHA {sha} within {PIPELINE_DISCOVERY_TIMEOUT}s", file=sys.stderr)
            sys.exit(1)
        remaining = deadline - time.monotonic()
        wait = min(interval, remaining)
        if wait > 0:
            print(f"No pipeline found yet for {sha[:12]}... retrying in {int(wait)}s")
            await asyncio.sleep(wait)


async def fetch_all_jobs(session: aiohttp.ClientSession, pipeline_ids: list[int]) -> list[dict]:
    tasks = [paginated_get(session, f"/projects/{PROJECT_ID}/pipelines/{pid}/jobs") for pid in pipeline_ids]
    results = await asyncio.gather(*tasks)
    all_jobs = []
    for job_list in results:
        if job_list:
            all_jobs.extend(job_list)
    return all_jobs


async def find_job_by_name(session: aiohttp.ClientSession, pipeline_ids: list[int], job_name: str, exact: bool) -> dict | None:
    """Find a job across pipelines. If exact, match the full name; otherwise substring."""
    all_jobs = await fetch_all_jobs(session, pipeline_ids)
    if exact:
        matches = [j for j in all_jobs if j.get("name") == job_name]
    else:
        matches = [j for j in all_jobs if job_name in j.get("name", "")]
    if not matches:
        return None
    if len(matches) > 1 and not exact:
        print(f"Multiple jobs match '{job_name}':")
        for j in matches:
            print(f"  [{j['id']}] {j['name']} ({j.get('status', '?')})")
        print("Use --job-name with the exact name or --job-id to disambiguate.", file=sys.stderr)
        sys.exit(1)
    # Prefer the most recent (highest ID) among exact matches
    return max(matches, key=lambda j: j["id"])


# ---------------------------------------------------------------------------
# Artifact download
# ---------------------------------------------------------------------------

async def download_job_artifacts(session: aiohttp.ClientSession, job_id: int, job_name: str, output_dir: Path) -> None:
    url = f"{API_BASE}/projects/{PROJECT_ID}/jobs/{job_id}/artifacts"
    print(f"Downloading artifacts for '{job_name}' (job {job_id})...")

    try:
        async with session.get(url) as resp:
            if resp.status == 404:
                print(f"Error: no artifacts found for job {job_id} ('{job_name}')", file=sys.stderr)
                sys.exit(1)
            if resp.status >= 400:
                text = await resp.text()
                print(f"Error: HTTP {resp.status} downloading artifacts: {text}", file=sys.stderr)
                sys.exit(1)
            total = int(resp.headers.get("content-length", 0))
            downloaded = 0
            tmp = tempfile.NamedTemporaryFile(suffix=".zip", delete=False)
            try:
                async for chunk in resp.content.iter_chunked(1024 * 1024):
                    tmp.write(chunk)
                    downloaded += len(chunk)
                    if total:
                        print(f"\r  {downloaded / 1e6:.1f}/{total / 1e6:.1f} MB ({downloaded / total * 100:.0f}%)", end="", flush=True)
                    else:
                        print(f"\r  {downloaded / 1e6:.1f} MB", end="", flush=True)
                tmp.close()
                print()
            except Exception:
                tmp.close()
                os.unlink(tmp.name)
                raise
    except aiohttp.ClientError as e:
        print(f"Error: network error downloading artifacts: {e}", file=sys.stderr)
        sys.exit(1)

    try:
        extract_zip(tmp.name, output_dir)
    finally:
        os.unlink(tmp.name)


def extract_zip(zip_path: str, output_dir: Path) -> None:
    output_dir.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(zip_path) as zf:
        names = [n for n in zf.namelist() if not n.endswith("/")]
        # Strip common leading directory (GitLab archives often wrap in a directory)
        parts = [n.split("/") for n in names]
        prefix = ""
        if parts and all(len(p) > 1 and p[0] == parts[0][0] for p in parts):
            prefix = parts[0][0] + "/"
        for member in zf.infolist():
            if member.filename.endswith("/"):
                continue
            member.filename = member.filename.removeprefix(prefix)
            zf.extract(member, output_dir)
        print(f"Extracted {len(names)} file(s) to {output_dir}:")
        for name in names:
            stripped = name.removeprefix(prefix)
            p = output_dir / stripped
            size = p.stat().st_size if p.is_file() else 0
            print(f"  {p}" + (f"  ({size / 1e6:.1f} MB)" if size else ""))


# ---------------------------------------------------------------------------
# High-level commands
# ---------------------------------------------------------------------------

async def cmd_job_id(session: aiohttp.ClientSession, job_id: int, output_dir: Path) -> None:
    """Download artifacts directly by job ID."""
    data = await api_get_json(session, f"/projects/{PROJECT_ID}/jobs/{job_id}")
    if not data:
        print(f"Error: could not fetch job {job_id}", file=sys.stderr)
        sys.exit(1)
    await download_job_artifacts(session, job_id, data.get("name", f"job-{job_id}"), output_dir)


async def cmd_job_name(session: aiohttp.ClientSession, job_name: str, pipeline_ids: list[int], output_dir: Path) -> None:
    """Download artifacts for a job found by name (substring match)."""
    job = await find_job_by_name(session, pipeline_ids, job_name, exact=False)
    if not job:
        print(f"Error: no job matching '{job_name}' found in pipelines {pipeline_ids}", file=sys.stderr)
        sys.exit(1)
    await download_job_artifacts(session, job["id"], job.get("name", ""), output_dir)


async def cmd_preset(session: aiohttp.ClientSession, preset_key: str, pipeline_ids: list[int], output_dir: Path) -> None:
    """Download a preset artifact."""
    all_jobs = await fetch_all_jobs(session, pipeline_ids)
    job_name = PRESET_JOBS[preset_key]
    matches = [j for j in all_jobs if j.get("name") == job_name]
    if not matches:
        print(f"Warning: preset '{preset_key}' (job '{job_name}') not found", file=sys.stderr)
        sys.exit(1)
    job = max(matches, key=lambda j: j["id"])
    await download_job_artifacts(session, job["id"], job_name, output_dir)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def parse_args():
    parser = argparse.ArgumentParser(
        description="Download CI artifacts from GitLab jobs.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"Available presets: {', '.join(sorted(PRESET_JOBS))}",
    )

    # What to download
    what = parser.add_mutually_exclusive_group(required=True)
    what.add_argument("--preset", metavar="KEY",
                      help="Download a well-known artifact by preset key")
    what.add_argument("--job-name", metavar="NAME",
                      help="Download artifacts from a job matched by name (substring)")
    what.add_argument("--job-id", type=int, metavar="ID",
                      help="Download artifacts directly by job ID")
    what.add_argument("--list-presets", action="store_true",
                      help="List available preset keys and exit")

    # How to find the pipeline
    source = parser.add_mutually_exclusive_group()
    source.add_argument("--pipeline", type=int, metavar="ID",
                        help="Pipeline ID to search for jobs")
    source.add_argument("--commit", metavar="REF",
                        help="Git ref to resolve to a SHA (default: HEAD)")

    parser.add_argument("--output-dir", "-o", metavar="DIR", default=".",
                        help="Output directory for downloaded artifacts (default: .)")

    return parser.parse_args()


async def run(args):
    if args.list_presets:
        print("Available preset keys:")
        for key, job_name in sorted(PRESET_JOBS.items()):
            print(f"  {key:<25} -> {job_name}")
        return

    token = os.environ.get("GITLAB_PERSONAL_ACCESS_TOKEN", "").strip()
    if not token:
        print("Error: GITLAB_PERSONAL_ACCESS_TOKEN environment variable is not set or empty", file=sys.stderr)
        sys.exit(1)

    output_dir = Path(args.output_dir)
    connector = aiohttp.TCPConnector(limit=20)
    headers = {"PRIVATE-TOKEN": token}
    async with aiohttp.ClientSession(headers=headers, connector=connector) as session:
        # --job-id needs no pipeline discovery
        if args.job_id is not None:
            await cmd_job_id(session, args.job_id, output_dir)
            return

        # Everything else needs pipeline IDs
        if args.pipeline is not None:
            root_id = args.pipeline
            print(f"Using pipeline {root_id}")
        else:
            ref = args.commit or "HEAD"
            sha = resolve_sha(ref)
            print(f"Resolved {ref} to {sha}")
            root_id = await discover_root_pipeline(session, sha)

        pipeline_ids = await get_all_pipeline_ids(session, root_id)
        print(f"Searching across {len(pipeline_ids)} pipeline(s): {pipeline_ids}")

        if args.preset is not None:
            if args.preset not in PRESET_JOBS:
                print(f"Error: unknown preset '{args.preset}'. Available: {', '.join(sorted(PRESET_JOBS))}", file=sys.stderr)
                sys.exit(1)
            await cmd_preset(session, args.preset, pipeline_ids, output_dir)
        elif args.job_name is not None:
            await cmd_job_name(session, args.job_name, pipeline_ids, output_dir)


def main():
    args = parse_args()
    asyncio.run(run(args))


if __name__ == "__main__":
    main()
