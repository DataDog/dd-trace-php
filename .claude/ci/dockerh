#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""
dockerh - Docker helper for dd-trace-php local CI reproduction.

Wraps `docker run` with automatic bind mounts for the repo checkout
(read-only) and a persistent cache overlay for build artifacts.
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile

CONTAINER_PROJECT = "/project/dd-trace-php"

# Overlays inside the project: repo-relative paths mounted as writable
# over the read-only checkout. Docker requires mountpoint dirs to exist
# on the base layer, so we create them in the checkout if missing (they
# are gitignored build artifact dirs).
PROJECT_OVERLAYS: list[str] = [
    "target",
    "profiling/target",
    "appsec/build",
    "tmp",
]


def repo_root() -> str:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        )
        return result.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        sys.exit("error: not inside a git repository")



def main() -> None:
    # Split on first bare "--" to separate dockerh+docker options from the
    # container command.
    argv = sys.argv[1:]
    cmd_args: list[str] | None = None
    if "--" in argv:
        idx = argv.index("--")
        pre = argv[:idx]
        cmd_args = argv[idx + 1:]
    else:
        pre = argv

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--cache", dest="cache_name", default=None)
    parser.add_argument("--clean-cache", action="store_true", default=False)
    parser.add_argument("--no-cache-overlay", action="store_true", default=False)
    parser.add_argument("--writable-tree", action="store_true", default=False,
                        help="Mount the repo read-write instead of read-only")
    parser.add_argument("--php", dest="php_variant", default=None,
                        metavar="VARIANT",
                        help="Call switch-php VARIANT before running (nts, zts, debug, nts-asan, debug-zts-asan)")
    parser.add_argument("--help", action="store_true", default=False)

    known, remaining = parser.parse_known_args(pre)

    if known.help:
        print(
            "Usage: dockerh --cache NAME [--no-cache-overlay] IMAGE [DOCKER_OPTIONS...] -- COMMAND [ARGS...]\n"
            "\n"
            "Wraps docker run with automatic repo mount (read-only) and\n"
            "persistent cache overlays for build artifacts.\n"
            "\n"
            "Options:\n"
            "  --cache NAME          Cache name (required); stored at ~/.cache/dd-ci/NAME/\n"
            "  --php VARIANT         Call switch-php before running (nts, zts, debug, nts-asan, debug-zts-asan)\n"
            "  --clean-cache         Delete the cache dir, then continue\n"
            "  --no-cache-overlay    Skip cache overlay mounts (--cache not required)\n"
            "  --writable-tree       Mount the repo read-write instead of read-only\n"
            "  --help                Show this help\n",
            file=sys.stderr,
        )
        sys.exit(0)

    if known.cache_name is None and (not known.no_cache_overlay or known.clean_cache):
        sys.exit("error: --cache NAME is required. Run with --help for usage.")

    if not remaining:
        sys.exit("error: IMAGE is required. Run with --help for usage.")

    image = remaining[0]
    docker_opts = remaining[1:]

    root = repo_root()
    cache_dir = os.path.expanduser(f"~/.cache/dd-ci/{known.cache_name}") if known.cache_name else None

    if known.clean_cache and cache_dir:
        if os.path.exists(cache_dir):
            shutil.rmtree(cache_dir)
            print(f"Removed {cache_dir}", file=sys.stderr)
        else:
            print(f"Cache dir does not exist: {cache_dir}", file=sys.stderr)

    uid = os.getuid()
    gid = os.getgid()

    docker_cmd = ["docker", "run", "--rm"]

    if sys.stdin.isatty():
        docker_cmd.append("-it")

    if known.php_variant:
        # datadog/dd-trace-ci images have a 'circleci' user (uid=3434, gid=3434)
        # with passwordless sudo, which is what switch-php needs.  Run as that
        # user and inject a minimal entrypoint that calls switch-php first.
        orig_ep = _image_entrypoint(image)
        tmpdir = tempfile.mkdtemp(prefix="dockerh-")
        entrypoint_path = os.path.join(tmpdir, "init.sh")
        if orig_ep:
            chain = "exec " + " ".join(_shell_quote(a) for a in orig_ep) + ' "$@"'
        else:
            chain = 'exec "$@"'
        with open(entrypoint_path, "w") as f:
            f.write(f"""#!/bin/sh
set -e
switch-php {known.php_variant}
{chain}
""")
        os.chmod(entrypoint_path, 0o755)
        docker_cmd += ["--user", "3434:3434"]
        docker_cmd += ["-e", "HOME=/tmp"]
        docker_cmd += ["-v", f"{entrypoint_path}:/dockerh-init.sh:ro"]
        docker_cmd += ["--entrypoint", "/dockerh-init.sh"]
    else:
        # Run as the host user so cache overlay dirs (owned by the host user)
        # are writable without any chmod hacks.  Works on Linux directly; on
        # macOS with OrbStack the host UID is mapped consistently into the VM.
        docker_cmd += ["--user", f"{uid}:{gid}"]
        # Provide a writable HOME so tools (cargo, etc.) that need to write to ~
        # don't fail when the UID has no passwd entry in the container.
        docker_cmd += ["-e", "HOME=/tmp"]

    # Checkout mount (read-only by default; read-write with --writable-tree)
    tree_mode = "" if known.writable_tree else ":ro"
    docker_cmd += ["-v", f"{root}:{CONTAINER_PROJECT}{tree_mode}"]

    # Cache overlay mounts
    if not known.no_cache_overlay:
        for repo_subdir in PROJECT_OVERLAYS:
            # Ensure the mountpoint dir exists in the checkout so Docker
            # can layer the writable bind mount on top of the :ro base.
            os.makedirs(os.path.join(root, repo_subdir), exist_ok=True)
            host_path = os.path.join(cache_dir, repo_subdir)  # type: ignore[arg-type]
            os.makedirs(host_path, exist_ok=True)
            if known.php_variant:
                # Running as circleci (uid=3434) inside the container, not as the
                # host user, so make the cache dirs world-writable.
                os.chmod(host_path, 0o777)
            docker_cmd += ["-v", f"{host_path}:{CONTAINER_PROJECT}/{repo_subdir}"]

    docker_cmd += ["-w", CONTAINER_PROJECT]

    # Pass through any extra docker options
    docker_cmd += docker_opts

    docker_cmd.append(image)

    if cmd_args is not None:
        docker_cmd += cmd_args
    # If no --, remaining args after image were consumed as docker_opts;
    # no command means docker default entrypoint runs.

    print("+ " + " ".join(_shell_quote(a) for a in docker_cmd), file=sys.stderr)
    os.execvp("docker", docker_cmd)


def _image_entrypoint(image: str) -> list[str]:
    try:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{json .Config.Entrypoint}}", image],
            capture_output=True, text=True, check=True,
        )
        val = json.loads(result.stdout.strip())
        return val if val else []
    except (subprocess.CalledProcessError, FileNotFoundError, json.JSONDecodeError):
        return []


def _shell_quote(s: str) -> str:
    if s and not re.search(r"[^\w@%+=:,./-]", s):
        return s
    return "'" + s.replace("'", "'\\''") + "'"


if __name__ == "__main__":
    main()
