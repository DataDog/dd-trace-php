#!/bin/bash

set -eo pipefail

# Function to get DataDog PHP extension download URL (monolithic per-PHP-API build)
# Usage: dd_php_release_url <extension_version> <php_version> <arch> <libc_type> <zts|nts>
# Example: dd_php_release_url "1.13.0" "8.4" "x86_64" "gnu" nts
dd_php_release_url() {
    local ext_version="$1"
    local php_version="$2"
    local arch="$3"
    local libc_type="$4"
    local thread_safety="$5"

    # Validate inputs
    if [[ -z "$ext_version" || -z "$php_version" || -z "$arch" || -z "$libc_type" || -z "$thread_safety" ]]; then
        echo "Error: Missing required parameters" >&2
        echo "Usage: dd_php_release_url <extension_version> <php_version> <arch> <libc_type> <zts|nts>" >&2
        echo "Example: dd_php_release_url '1.13.0' '8.4' 'x86_64' 'gnu' nts" >&2
        return 1
    fi

    # Validate thread safety
    if [[ "$thread_safety" != "zts" && "$thread_safety" != "nts" ]]; then
        echo "Error: Invalid thread safety: $thread_safety (must be zts or nts)" >&2
        return 1
    fi

    # Map PHP versions to API numbers
    local api_version
    case "$php_version" in
        8.5) api_version="20250925" ;;
        8.4) api_version="20240924" ;;
        8.3) api_version="20230831" ;;
        8.2) api_version="20220829" ;;
        8.1) api_version="20210902" ;;
        8.0) api_version="20200930" ;;
        7.4) api_version="20190902" ;;
        7.3) api_version="20180731" ;;
        7.2) api_version="20170718" ;;
        7.1) api_version="20160303" ;;
        7.0) api_version="20151012" ;;
        *)
            echo "Error: Unsupported PHP version: $php_version" >&2
            echo "Supported versions: 7.0, 7.1, 7.2, 7.3, 7.4, 8.0, 8.1, 8.2, 8.3, 8.4, 8.5" >&2
            return 1
            ;;
    esac

    # Validate arch
    if [[ "$arch" != "x86_64" && "$arch" != "arm64" && "$arch" != "aarch64" ]]; then
        echo "Error: Invalid architecture: $arch (must be x86_64, arm64, or aarch64)" >&2
        return 1
    fi

    # Normalize aarch64 to arm64
    [[ "$arch" == "aarch64" ]] && arch="arm64"

    # Validate libc type
    if [[ "$libc_type" != "gnu" && "$libc_type" != "musl" ]]; then
        echo "Error: Invalid libc type: $libc_type (must be gnu or musl)" >&2
        return 1
    fi

    # ZTS builds have a -zts suffix; NTS builds have no suffix
    local zts_suffix=""
    [[ "$thread_safety" == "zts" ]] && zts_suffix="-zts"

    # Construct the URL
    local url="https://github.com/DataDog/dd-trace-php/releases/download/${ext_version}/dd-library-php-${ext_version}-${arch}-linux-${libc_type}-${api_version}${zts_suffix}.tar.gz"

    echo "$url"
}

# Download the SSI PHP package from install.datadoghq.com (public OCI registry, no auth needed).
# OCI tags use the format "<version>-N" (e.g. 1.18.0-1); the latest revision is resolved
# automatically. The layer is a zstd-compressed tar with linux-gnu/ and linux-musl/ trees.
#
# Usage: dd_php_ssi_download <extension_version> <arch> <destdir>
# arch: x86_64 or aarch64
dd_php_ssi_download() {
    local ext_version="$1"
    local arch="$2"
    local destdir="$3"

    if [[ -z "$ext_version" || -z "$arch" || -z "$destdir" ]]; then
        echo "Error: Missing required parameters" >&2
        echo "Usage: dd_php_ssi_download <extension_version> <arch> <destdir>" >&2
        return 1
    fi

    # OCI registry uses amd64/arm64 platform names
    local oci_arch
    case "$arch" in
        x86_64|amd64)   oci_arch="amd64" ;;
        aarch64|arm64)  oci_arch="arm64" ;;
        *)
            echo "Error: Invalid architecture: $arch (must be x86_64 or aarch64)" >&2
            return 1
            ;;
    esac

    local base_url="https://install.datadoghq.com/v2/apm-library-php-package"

    # OCI tags are "VERSION-N"; find the latest revision for this version
    local tag
    tag=$(curl -sf "${base_url}/tags/list" | jq -r \
        --arg v "$ext_version" \
        '[.tags[] | select(startswith($v + "-"))] | sort | last // empty')
    if [[ -z "$tag" ]]; then
        echo "Error: No OCI tag found for version $ext_version" >&2
        echo "Available tags: $(curl -sf "${base_url}/tags/list" | jq -r '.tags[]' | tr '\n' ' ')" >&2
        return 1
    fi

    echo "Fetching SSI package ${ext_version} (${arch}) from install.datadoghq.com tag ${tag}..." >&2

    # Resolve the image index to the per-arch manifest digest
    local platform_digest
    platform_digest=$(curl -sf \
        -H "Accept: application/vnd.oci.image.index.v1+json" \
        "${base_url}/manifests/${tag}" \
        | jq -r --arg arch "$oci_arch" \
            '.manifests[] | select(.platform.architecture == $arch) | .digest')

    if [[ -z "$platform_digest" ]]; then
        echo "Error: could not find ${oci_arch} manifest in index for tag ${tag}" >&2
        return 1
    fi

    # Get the layer blob digest from the per-arch manifest
    local layer_digest
    layer_digest=$(curl -sf \
        -H "Accept: application/vnd.oci.image.manifest.v1+json" \
        "${base_url}/manifests/${platform_digest}" \
        | jq -r '.layers[0].digest')

    if [[ -z "$layer_digest" ]]; then
        echo "Error: could not find layer digest in manifest" >&2
        return 1
    fi

    echo "Downloading layer ${layer_digest}..." >&2
    curl -sfL "${base_url}/blobs/${layer_digest}" | zstd -d | tar -x -C "$destdir"
}

main() {
  set -x
  local tmpdir
  tmpdir=$(mktemp -d /tmp/crash_binaries.XXXXXXXXXX)

  if [[ "${1:-}" == "--ssi" ]]; then
    shift
    dd_php_ssi_download "$1" "$2" "$tmpdir"
  else
    local url
    url=$(dd_php_release_url "$@")
    curl -sLf -o - "$url" | tar -C "$tmpdir" -xzf -
  fi

  echo "$tmpdir"
}

main "$@"
